# Copia este archivo a ".env" (mismo directorio) antes de correr "pnpm run android".
# 10.0.2.2 es la IP especial que el emulador de Android Studio usa para
# alcanzar "localhost" de tu maquina anfitriona (host). NO uses "localhost"
# aqui o la app movil no podra hablar con los servicios que corren en tu PC.

# auth-service (.NET) -> docker-compose (postgres) + `dotnet run` (o `docker-compose up`)
EXPO_PUBLIC_AUTH_URL=http://10.0.2.2:5156/api/v1/auth

# server-user (Node/Express) -> `pnpm run dev` dentro de KinalSportsIN6BM/server-user
EXPO_PUBLIC_USER_URL=http://10.0.2.2:3003/kinalSportsUser/v1
