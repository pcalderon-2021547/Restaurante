# Configuración para el cliente Expo
# 
# Android Emulator:  usa 10.0.2.2 (mapea a localhost del host)
# iOS Simulator:     usa localhost
# Dispositivo físico: usa la IP local de tu máquina (ej: 192.168.x.x)
# 
# El puerto por defecto del backend server-restaurant es 3010
# 
# Si no se definen, se usan valores por defecto según la plataforma:
#   Android -> http://10.0.2.2:3010/restaurantManagement/v1
#   iOS/Web -> http://localhost:3010/restaurantManagement/v1

EXPO_PUBLIC_AUTH_URL=http://10.0.2.2:3010/restaurantManagement/v1/auth
EXPO_PUBLIC_USER_URL=http://10.0.2.2:3010/restaurantManagement/v1
