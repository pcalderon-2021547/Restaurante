# Android Studio AVD (Pixel 8): usa 10.0.2.2 para llegar al "localhost" de tu PC.
# Si en vez del emulador usas un dispositivo fisico en la misma red WiFi,
# reemplaza 10.0.2.2 por la IP local de tu maquina (ej. 192.168.x.x) y
# asegurate de que server-user y auth-service acepten conexiones externas.
EXPO_PUBLIC_AUTH_URL=http://10.0.2.2:5156/api/v1/auth

EXPO_PUBLIC_USER_URL=http://10.0.2.2:3003/kinalSportsUser/v1
