{
  "info": {
    "_postman_id": "delivery-api-collection",
    "name": "Restaurant Delivery API",
    "description": "Colección completa de endpoints para gestionar entregas a domicilio",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Deliveries",
      "item": [
        {
          "name": "Create Delivery",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order\": \"64b9c3e4f8d5a1b2c3d4e5f6\",\n  \"deliveryAddress\": {\n    \"street\": \"Calle Principal\",\n    \"number\": \"123\",\n    \"neighborhood\": \"Centro\",\n    \"city\": \"Bogotá\",\n    \"postalCode\": \"110221\",\n    \"reference\": \"Edificio azul cerca al parque\",\n    \"latitude\": 4.5904,\n    \"longitude\": -74.0721\n  },\n  \"deliveryZone\": \"Centro\",\n  \"distance\": 5.5,\n  \"deliveryFee\": 8000,\n  \"estimatedDeliveryTime\": 30,\n  \"paymentMethod\": \"cash\",\n  \"specialInstructions\": \"Llamar al llegar al edificio\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/deliveries",
              "host": ["{{base_url}}"],
              "path": ["api", "deliveries"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Deliveries",
          "request": {
