              "raw": "{\n  \"specialInstructions\": \"Llamar antes de llegar\",\n  \"estimatedDeliveryTime\": 45\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/deliveries/{{delivery_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "deliveries", "{{delivery_id}}"]
            }
          },
          "response": []
        },
